generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  UPLOADED
  EXTRACTING
  EXTRACTED
  ANALYZING
  READY
  FAILED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum FileType {
  PDF
  PPTX
  DOCX
  EPUB
}

enum JobType {
  EXTRACT_TEXT
  CHUNK_DOCUMENT
  EMBED_DOCUMENT
  ANALYZE_DOCUMENT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentTagSource {
  AI
  USER
  MERGED
}

enum TagMergeReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  accounts        Account[]
  sessions        Session[]
  documents       Document[]
  projects        Project[]
  aiProviders     AiProvider[]
  createdTags     Tag[]            @relation("TagCreator")
  tagMergeReviews TagMergeReview[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Document {
  id               String           @id @default(cuid())
  userId           String
  title            String
  originalFileName String
  fileType         FileType
  filePath         String
  fileSize         Int
  textContent      String?
  language         String?
  primaryTopic     String?
  difficulty       Difficulty?
  summary          String?
  subtopics        String[]         @default([])
  keywords         String[]         @default([])
  analysisReason   String?
  status           DocumentStatus   @default(UPLOADED)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks           DocumentChunk[]
  jobs             AnalysisJob[]
  recommendations  Recommendation[]
  tags             DocumentTag[]
  tagMergeReviews  TagMergeReview[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([primaryTopic])
}

model Tag {
  id              String                       @id @default(cuid())
  name            String
  normalizedName  String
  description     String?
  embedding       Unsupported("vector(1024)")?
  createdByUserId String
  createdByUser   User                         @relation("TagCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  aliases         TagAlias[]
  documents       DocumentTag[]
  mergeReviews    TagMergeReview[]             @relation("SuggestedTag")
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@unique([createdByUserId, normalizedName])
  @@index([createdByUserId, name])
}

model TagAlias {
  id              String   @id @default(cuid())
  tagId           String
  alias           String
  normalizedAlias String
  tag             Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([tagId, normalizedAlias])
  @@index([normalizedAlias])
}

model DocumentTag {
  documentId String
  tagId      String
  confidence Float             @default(1)
  source     DocumentTagSource @default(AI)
  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag               @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@id([documentId, tagId])
  @@index([tagId])
}

model TagMergeReview {
  id                      String                       @id @default(cuid())
  userId                  String
  documentId              String?
  candidateTagName        String
  candidateNormalizedName String
  candidateEmbedding      Unsupported("vector(1024)")?
  suggestedTagId          String
  similarity              Float
  status                  TagMergeReviewStatus         @default(PENDING)
  user                    User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  document                Document?                    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  suggestedTag            Tag                          @relation("SuggestedTag", fields: [suggestedTagId], references: [id], onDelete: Cascade)
  createdAt               DateTime                     @default(now())
  resolvedAt              DateTime?

  @@index([userId, status, createdAt])
  @@index([suggestedTagId, status])
  @@index([documentId])
}

model AnalysisJob {
  id           String    @id @default(cuid())
  documentId   String
  type         JobType
  status       JobStatus @default(PENDING)
  progress     Int       @default(0)
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([documentId, createdAt])
  @@index([status, type])
}

model DocumentChunk {
  id          String                       @id @default(cuid())
  documentId  String
  chunkIndex  Int
  content     String
  tokenCount  Int?
  pageNumber  Int?
  sourceLabel String?
  embedding   Unsupported("vector(1024)")?
  document    Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime                     @default(now())

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

model Project {
  id               String           @id @default(cuid())
  userId           String
  title            String
  description      String
  keywords         String[]         @default([])
  targetDifficulty Difficulty?
  embedding        Unsupported("vector(1024)")?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations  Recommendation[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId, createdAt])
}

model Recommendation {
  id         String   @id @default(cuid())
  projectId  String
  documentId String
  score      Float
  reason     String?
  bestChunkId String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([projectId, documentId])
}

model AiProvider {
  id                    String   @id @default(cuid())
  userId                String
  type                  String
  displayName           String
  baseUrl               String?
  apiKeyEncrypted       String?
  defaultChatModel      String?
  defaultEmbeddingModel String?
  isActive              Boolean  @default(false)
  authStatus            String   @default("DISCONNECTED")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}
